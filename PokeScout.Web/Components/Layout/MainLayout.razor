@inherits LayoutComponentBase
@using Microsoft.AspNetCore.WebUtilities
@inject NavigationManager Navigation

<div class="page-shell">
    <input id="sidebar-toggle" class="sidebar-toggle-input" type="checkbox" />

    <aside class="sidebar-shell">
        <NavMenu />
    </aside>

    <label for="sidebar-toggle"
           class="sidebar-backdrop"
           aria-label="Close sidebar">
    </label>

    <main class="main-shell">
        <header class="app-header">
            <div class="topbar-shell">
                <div class="topbar-row">
                    <label for="sidebar-toggle"
                           class="menu-toggle"
                           aria-label="Toggle navigation">
                        <span></span>
                        <span></span>
                        <span></span>
                    </label>

                    <a href="/" class="center-logo-link" aria-label="Go to home page">
                        <img src="images/pokescout-logo.png" alt="PokeScout logo" class="center-logo-image" />
                    </a>
                </div>

                <form class="search-shell" method="get" action="/catalog">
                    <span class="search-icon">⌕</span>
                    <input class="global-search-input"
                           type="search"
                           name="search"
                           value="@CurrentSearchValue"
                           placeholder="Search cards, sets, decks, or products" />
                </form>
            </div>
        </header>

        <article class="content-shell">
            @Body
        </article>
    </main>
</div>

@code {
    private string CurrentSearchValue
    {
        get
        {
            var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
            var query = QueryHelpers.ParseQuery(uri.Query);

            if (query.TryGetValue("search", out var value))
            {
                return value.ToString();
            }

            return string.Empty;
        }
    }
}