@using System.Net.Http.Json
@using PokeScout.Web.Models
@inject HttpClient Http
@inject NavigationManager Navigation

<div class="ps-shop-card">
    <div class="ps-shop-card-glow"></div>

    <div class="ps-shop-image-wrap">
        @if (!string.IsNullOrWhiteSpace(Item.ImageUrl))
        {
            <img src="@Item.ImageUrl" alt="@Item.Title" class="ps-shop-image" />
        }
        else
        {
            <div class="ps-shop-image-placeholder">
                <span>No Image Yet</span>
            </div>
        }

        <div class="ps-shop-tier">@Item.Tier</div>
    </div>

    <div class="ps-shop-body">
        <div class="ps-shop-title-row">
            <h3>@Item.Title</h3>
            <span class="ps-shop-stock">Stock: @Item.StockCount</span>
        </div>

        <p class="ps-shop-description">@Item.Description</p>

        <div class="ps-shop-meta">
            <div class="ps-meta-pill">
                <span class="ps-meta-label">Condition</span>
                <strong>@Item.Condition</strong>
            </div>

            <div class="ps-meta-pill">
                <span class="ps-meta-label">Checkout</span>
                <strong>@(Item.IsStripeReady ? "Stripe Ready" : "Coming Soon")</strong>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(errorMessage))
        {
            <div class="ps-shop-error">
                @errorMessage
            </div>
        }

        <div class="ps-shop-footer">
            <div class="ps-shop-price">
                $@Item.Price.ToString("0.00")
            </div>

            <button class="ps-shop-button"
                    @onclick="StartCheckoutAsync"
                    disabled="@(!Item.IsStripeReady || isLoading)">
                @(isLoading ? "Redirecting..." : Item.ButtonText)
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ShopCatalogItem Item { get; set; } = new();

    private bool isLoading;
    private string? errorMessage;

    private async Task StartCheckoutAsync()
    {
        if (!Item.IsStripeReady || string.IsNullOrWhiteSpace(Item.Id))
            return;

        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/shop/checkout-session",
                new CreateCheckoutSessionRequest
                {
                    ProductId = Item.Id
                });

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Checkout failed. Please try again.";
                return;
            }

            var result = await response.Content.ReadFromJsonAsync<CreateCheckoutSessionResponse>();

            if (result is null || string.IsNullOrWhiteSpace(result.Url))
            {
                errorMessage = "Stripe session URL was missing.";
                return;
            }

            Navigation.NavigateTo(result.Url, forceLoad: true);
        }
        catch
        {
            errorMessage = "Something went wrong starting checkout.";
        }
        finally
        {
            isLoading = false;
        }
    }

    public class CreateCheckoutSessionRequest
    {
        public string ProductId { get; set; } = string.Empty;
    }

    public class CreateCheckoutSessionResponse
    {
        public string Url { get; set; } = string.Empty;
    }
}