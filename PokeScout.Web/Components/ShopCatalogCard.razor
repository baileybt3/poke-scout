@using PokeScout.Web.Models

<div class="card h-100 shop-card shadow-sm border-0">
    <div class="shop-card-image">
        Image coming soon
    </div>

    <div class="card-body d-flex flex-column">
        <div class="d-flex justify-content-between align-items-start mb-2">
            <h5 class="card-title mb-0">@Item.Title</h5>
            <span class="badge bg-dark">@Item.Tier</span>
        </div>

        <p class="text-muted mb-3">@Item.Description</p>

        <div class="small mb-3">
            <div><strong>Condition:</strong> @Item.Condition</div>
            <div><strong>Stock:</strong> @Item.StockCount</div>
        </div>

        <div class="mt-auto d-flex justify-content-between align-items-center">
            <span class="fw-bold fs-5">$@Item.Price.ToString("0.00")</span>

            <button class="btn btn-primary" disabled="@(!Item.IsStripeReady)">
                @Item.ButtonText
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public ShopCatalogItem Item { get; set; } = new();
}