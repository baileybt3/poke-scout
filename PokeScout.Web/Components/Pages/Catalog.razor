            cursor: not-allowed;
        }

    .catalog-message {
        padding: 1rem 1.1rem;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
    }

        .catalog-message.error {
            color: #ff9c9c;
        }

    .catalog-loading-grid,
    .catalog-results-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
        gap: 1rem;
    }

    .catalog-skeleton-card {
        height: 360px;
        border-radius: 22px;
        background: linear-gradient(90deg, rgba(255,255,255,0.03), rgba(255,255,255,0.07), rgba(255,255,255,0.03));
        border: 1px solid rgba(255,255,255,0.06);
    }

    .catalog-card {
        display: flex;
        flex-direction: column;
        overflow: hidden;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: transform 0.18s ease, border-color 0.18s ease, background 0.18s ease;
    }

        .catalog-card:hover {
            transform: translateY(-4px);
            border-color: rgba(79, 140, 255, 0.26);
            background: rgba(255, 255, 255, 0.06);
        }

    .catalog-card-image-wrap {
        padding: 0.95rem;
        background: rgba(255, 255, 255, 0.03);
    }

    .catalog-card-image {
        width: 100%;
        display: block;
        border-radius: 16px;
    }

    .catalog-card-body {
        display: grid;
        gap: 0.65rem;
        padding: 1rem;
    }

    .catalog-card-set {
        font-size: 0.8rem;
        font-weight: 800;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: #8fb9ff;
    }

    .catalog-card-body h3 {
        margin: 0;
        font-size: 1rem;
        line-height: 1.35;
    }

    .catalog-card-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
    }

        .catalog-card-meta span {
            padding: 0.35rem 0.55rem;
            border-radius: 999px;
            font-size: 0.78rem;
            color: rgba(255, 255, 255, 0.76);
            background: rgba(255, 255, 255, 0.06);
        }

    .catalog-card-link {
        color: #9ec2ff;
        font-weight: 700;
        text-decoration: none;
    }

        .catalog-card-link:hover {
            text-decoration: underline;
        }

    @@media (max-width: 900px) {
        .catalog-hero

    {
        grid-template-columns: 1fr;
    }

    }

    @@media (max-width: 640px) {
        .catalog-search-header

    {
        flex-direction: column;
        align-items: flex-start;
    }

    .primary-action,
    .secondary-action,
    .catalog-search-button {
        width: 100%;
    }

    }
</style>

@code {
    private const string ApiBaseUrl = "https://localhost:7034";

    [SupplyParameterFromQuery(Name = "search")]
    public string? Search { get; set; }

    private string searchTerm = "";
    private bool isLoading;
    private string? error;
    private List<CatalogSearchResultDto>? results;
    private string? lastExecutedSearch;

    protected override async Task OnParametersSetAsync()
    {
        var incomingSearch = Search?.Trim();

        if (!string.IsNullOrWhiteSpace(incomingSearch) &&
            !string.Equals(incomingSearch, lastExecutedSearch, StringComparison.OrdinalIgnoreCase))
        {
            searchTerm = incomingSearch;
            await SearchAsync(incomingSearch);
        }
    }

    private async Task HandleSubmitAsync()
    {
        var trimmedSearch = searchTerm.Trim();

        if (string.IsNullOrWhiteSpace(trimmedSearch))
        {
            error = "Enter a card name.";
            results = null;
            return;
        }

        var currentQuerySearch = Search?.Trim();

        if (!string.Equals(trimmedSearch, currentQuerySearch, StringComparison.OrdinalIgnoreCase))
        {
            Navigation.NavigateTo($"/catalog?search={Uri.EscapeDataString(trimmedSearch)}");
            return;
        }

        await SearchAsync(trimmedSearch);
    }

    private async Task SearchAsync(string term)
    {
        error = null;
        results = null;
        isLoading = true;
        lastExecutedSearch = term;

        try
        {
            results = await Http.GetFromJsonAsync<List<CatalogSearchResultDto>>(
                $"api/catalog/search?name={Uri.EscapeDataString(term)}") ?? new();
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }

    private void GoToSetsPage()
    {
        Navigation.NavigateTo("/sets");
    }

    private void GoToMyCardsPage()
    {
        Navigation.NavigateTo("/cards");
    }

    private static string GetImageUrl(string imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
            return "";

        if (imageUrl.StartsWith("http://", StringComparison.OrdinalIgnoreCase) ||
            imageUrl.StartsWith("https://", StringComparison.OrdinalIgnoreCase))
        {
            return imageUrl;
        }

        return $"{ApiBaseUrl}{imageUrl}";
    }

    private sealed class CatalogSearchResultDto
    {
        public string ExternalId { get; set; } = "";
        public string Name { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string SetName { get; set; } = "";
        public string Series { get; set; } = "";
        public string Rarity { get; set; } = "";
        public decimal? MarketPrice { get; set; }
        public string TcgPlayerUrl { get; set; } = "";
    }
}