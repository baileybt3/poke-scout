        display: grid;
        gap: 1.5rem;
    }

    .catalog-hero {
        display: grid;
        grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
        gap: 1rem;
        padding: 1.5rem;
        border-radius: 26px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255, 255, 255, 0.08);
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.18);
    }

    .catalog-hero-copy h1 {
        margin: 0 0 0.65rem 0;
    }

    .catalog-eyebrow {
        margin-bottom: 0.55rem;
        font-size: 0.82rem;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        color: #8fb9ff;
    }

    .catalog-hero-copy p {
        margin: 0;
        max-width: 700px;
        line-height: 1.65;
        color: rgba(255, 255, 255, 0.76);
    }

    .catalog-hero-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin-top: 1.2rem;
    }

    .primary-action,
    .secondary-action,
    .catalog-search-button {
        border: none;
        border-radius: 999px;
        padding: 0.85rem 1.15rem;
        font-weight: 700;
        cursor: pointer;
        transition: transform 0.18s ease, opacity 0.18s ease, background 0.18s ease;
    }

    .primary-action {
        background: linear-gradient(135deg, #4f8cff, #7a5cff);
        color: white;
    }

    .secondary-action {
        background: rgba(255, 255, 255, 0.06);
        color: white;
        border: 1px solid rgba(255, 255, 255, 0.12);
    }

        .primary-action:hover,
        .secondary-action:hover,
        .catalog-search-button:hover {
            transform: translateY(-1px);
        }

    .catalog-hero-panel {
        padding: 1.1rem;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
    }

    .hero-panel-title {
        margin-bottom: 0.9rem;
        font-size: 0.92rem;
        font-weight: 800;
        color: #dbeafe;
    }

    .hero-panel-list {
        display: grid;
        gap: 0.8rem;
    }

    .hero-panel-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: rgba(255, 255, 255, 0.76);
    }

    .hero-badge {
        width: 1.8rem;
        height: 1.8rem;
        display: inline-grid;
        place-items: center;
        border-radius: 999px;
        font-size: 0.8rem;
        font-weight: 800;
        color: white;
        background: linear-gradient(135deg, rgba(79, 140, 255, 0.8), rgba(122, 92, 255, 0.8));
        flex-shrink: 0;
    }

    .catalog-search-shell {
        padding: 1.35rem;
        border-radius: 24px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid rgba(255, 255, 255, 0.07);
    }

    .catalog-search-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

        .catalog-search-header h2 {
            margin: 0 0 0.35rem 0;
        }

        .catalog-search-header p {
            margin: 0;
            color: rgba(255, 255, 255, 0.7);
        }

    .results-pill {
        padding: 0.45rem 0.7rem;
        border-radius: 999px;
        font-size: 0.82rem;
        font-weight: 700;
        color: #dbeafe;
        background: rgba(79, 140, 255, 0.14);
        border: 1px solid rgba(79, 140, 255, 0.2);
        white-space: nowrap;
    }

    .catalog-search-form {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 1rem;
    }

    .catalog-search-input {
        flex: 1;
        min-width: 240px;
        padding: 0.95rem 1rem;
        border-radius: 16px;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: rgba(255, 255, 255, 0.05);
        color: white;
        outline: none;
    }

        .catalog-search-input::placeholder {
            color: rgba(255, 255, 255, 0.48);
        }

        .catalog-search-input:focus {
            border-color: rgba(79, 140, 255, 0.55);
            box-shadow: 0 0 0 4px rgba(79, 140, 255, 0.12);
        }

    .catalog-search-button {
        padding-inline: 1.3rem;
        background: #5a67d8;
        color: white;
    }

        .catalog-search-button:disabled {
