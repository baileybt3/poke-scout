@page "/catalog"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>Cards</PageTitle>

<div class="catalog-page">
    <section class="catalog-hero">
        <div class="catalog-hero-copy">
            <div class="catalog-eyebrow">Pokémon Catalog</div>
            <h1>Cards</h1>
            <p>
                Search for any Pokémon card or open the full set browser to explore every expansion in order.
            </p>

            <div class="catalog-hero-actions">
                <button type="button" class="primary-action" @onclick="GoToSetsPage">
                    Browse All Sets
                </button>

                <button type="button" class="secondary-action" @onclick="GoToMyCardsPage">
                    Go to My Cards
                </button>
            </div>
        </div>

        <div class="catalog-hero-panel">
            <div class="hero-panel-title">What you can do here</div>

            <div class="hero-panel-list">
                <div class="hero-panel-item">
                    <span class="hero-badge">1</span>
                    <span>Search by Pokémon name</span>
                </div>

                <div class="hero-panel-item">
                    <span class="hero-badge">2</span>
                    <span>Open every set in chronological order</span>
                </div>

                <div class="hero-panel-item">
                    <span class="hero-badge">3</span>
                    <span>View all cards inside a selected set</span>
                </div>
            </div>
        </div>
    </section>

    <section class="catalog-search-shell">
        <div class="catalog-search-header">
            <div>
                <h2>Quick Search</h2>
                <p>Find a card fast, or browse the full set explorer.</p>
            </div>

            @if (results is not null && !isLoading && string.IsNullOrWhiteSpace(error))
            {
                <div class="results-pill">
                    @results.Count result@(results.Count == 1 ? "" : "s")
                </div>
            }
        </div>

        <form class="catalog-search-form"
              @onsubmit="HandleSubmitAsync"
              @onsubmit:preventDefault>
            <input @bind="searchTerm"
                   class="catalog-search-input"
                   placeholder="Search Pokémon card name..." />

            <button type="submit" class="catalog-search-button" disabled="@isLoading">
                @(isLoading ? "Searching..." : "Search")
            </button>
        </form>

        @if (!string.IsNullOrWhiteSpace(error))
        {
            <div class="catalog-message error">
                @error
            </div>
        }
        else if (isLoading)
        {
            <div class="catalog-loading-grid">
                @for (var i = 0; i < 8; i++)
                {
                    <div class="catalog-skeleton-card"></div>
                }
            </div>
        }
        else if (results is not null && results.Count == 0)
        {
            <div class="catalog-message">
                No results found.
            </div>
        }
        else if (results is not null)
        {
            <div class="catalog-results-grid">
                @foreach (var card in results)
                {
                    <article class="catalog-card">
                        <div class="catalog-card-image-wrap">
                            @if (!string.IsNullOrWhiteSpace(card.ImageUrl))
                            {
                                <img src="@GetImageUrl(card.ImageUrl)"
                                     alt="@card.Name"
                                     class="catalog-card-image" />
                            }
                        </div>

                        <div class="catalog-card-body">
                            <div class="catalog-card-set">@card.SetName</div>
                            <h3>@card.Name</h3>

                            <div class="catalog-card-meta">
                                @if (!string.IsNullOrWhiteSpace(card.Rarity))
                                {
                                    <span>@card.Rarity</span>
                                }

                                @if (card.MarketPrice.HasValue)
                                {
                                    <span>@card.MarketPrice.Value.ToString("C")</span>
                                }
                            </div>

                            @if (!string.IsNullOrWhiteSpace(card.TcgPlayerUrl))
                            {
                                <a class="catalog-card-link"
                                   href="@card.TcgPlayerUrl"
                                   target="_blank"
                                   rel="noopener noreferrer">
                                    View Market Link
                                </a>
                            }
                        </div>
                    </article>
                }
            </div>
        }
    </section>
</div>

<style>
