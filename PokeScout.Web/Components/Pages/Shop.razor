@page "/shop"
@rendermode InteractiveServer
@using System.Net.Http.Json
@using PokeScout.Web.Models
@inject HttpClient Http

<PageTitle>Shop | PokeScout</PageTitle>

<div class="ps-shop-page">
    <section class="ps-shop-hero">
        <div class="ps-shop-hero-copy">
            <div class="ps-shop-kicker">PokeScout Storefront</div>
            <h1>Shop curated Pokémon deck products.</h1>
            <p>
                Clean product cards, live Stripe checkout, and a storefront that matches the rest of the app.
            </p>
        </div>
    </section>

    @if (isLoading)
    {
        <div class="ps-shop-state-card">
            <p>Loading shop...</p>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(errorMessage))
    {
        <div class="ps-shop-error-card">
            @errorMessage
        </div>
    }
    else if (items.Count == 0)
    {
        <div class="ps-shop-state-card">
            <p>No shop items found.</p>
        </div>
    }
    else
    {
        <section class="ps-shop-grid">
            @foreach (var item in items)
            {
                <ShopCatalogCard Item="item" />
            }
        </section>
    }
</div>

@code {
    private bool isLoading = true;
    private string? errorMessage;
    private List<ShopCatalogItem> items = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            items = await Http.GetFromJsonAsync<List<ShopCatalogItem>>("api/shop") ?? new();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}