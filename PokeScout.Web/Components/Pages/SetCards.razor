@page "/setcards/{SetId}"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation

<PageTitle>@PageTitle</PageTitle>

<div class="set-cards-page">
    <section class="set-cards-hero">
        <div>
            <div class="set-cards-eyebrow">Set Browser</div>
            <h1>@Heading</h1>
            <p>@Subheading</p>
        </div>

        <button class="back-button" type="button" @onclick="GoBack">
            ← Back to Sets
        </button>
    </section>

    <div class="set-toolbar">
        <input class="set-toolbar-input"
               @bind="searchTerm"
               @bind:event="oninput"
               placeholder="Search card name..." />

        <select class="set-toolbar-select" @bind="selectedSort">
            <option value="number">Card Number</option>
            <option value="name-asc">Name A–Z</option>
            <option value="name-desc">Name Z–A</option>
            <option value="rarity">Rarity</option>
            <option value="price-asc">Price Low → High</option>
            <option value="price-desc">Price High → Low</option>
        </select>

        <select class="set-toolbar-select" @bind="selectedRarity">
            <option value="">All Rarities</option>
            @foreach (var rarity in AvailableRarities)
            {
                <option value="@rarity">@rarity</option>
            }
        </select>

        @if (!string.IsNullOrWhiteSpace(searchTerm) || !string.IsNullOrWhiteSpace(selectedRarity) || selectedSort != "number")
        {
            <button class="set-toolbar-clear" type="button" @onclick="ClearFilters">
                Reset
            </button>
        }
    </div>

    @if (isLoading)
    {
        <div class="set-cards-message">Loading cards...</div>
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="set-cards-message error">@error</div>
    }
    else if (FilteredCards.Count == 0)
    {
        <div class="set-cards-message">No cards matched your filters.</div>
    }
    else
    {
        <div class="set-cards-message">
            Showing <strong>@FilteredCards.Count</strong> of <strong>@allCards.Count</strong> cards.
        </div>

        <div class="cards-grid">
            @foreach (var card in FilteredCards)
            {
                <article class="card-tile">
                    <div class="card-image-wrap">
                        <img class="card-image"
                             src="@GetApiImageUrl(card.ImageUrl)"
                             alt="@card.Name"
                             loading="lazy" />
                    </div>

                    <div class="card-info">
                        <p class="card-number">#@card.Number</p>
                        <h3>@card.Name</h3>

                        <div class="card-meta">
                            @if (!string.IsNullOrWhiteSpace(card.Rarity))
                            {
                                <span>@card.Rarity</span>
                            }

                            @if (card.MarketPrice is not null)
                            {
                                <span>@card.MarketPrice.Value.ToString("C")</span>
                            }
                        </div>

                        @if (!string.IsNullOrWhiteSpace(card.TcgPlayerUrl))
                        {
                            <a class="card-link"
                               href="@card.TcgPlayerUrl"
                               target="_blank"
                               rel="noopener noreferrer">
                                View market
                            </a>
                        }
                    </div>
                </article>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public string SetId { get; set; } = "";

    private readonly List<SetCardItem> allCards = [];
    private bool isLoading = true;
    private string? error;
    private string searchTerm = "";
    private string selectedSort = "number";
    private string selectedRarity = "";
    private string setName = "";

    private string PageTitle =>
        string.IsNullOrWhiteSpace(setName) ? "Set Cards" : $"{setName} Cards";

    private string Heading =>
        string.IsNullOrWhiteSpace(setName) ? "Set Cards" : setName;

    private string Subheading =>
        allCards.Count == 0
            ? "Browse cards from this Pokémon TCG set."
            : $"{allCards.Count} cards loaded from this set.";

    private List<string> AvailableRarities =>
        allCards
            .Select(x => x.Rarity?.Trim())
            .Where(x => !string.IsNullOrWhiteSpace(x))
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .OrderBy(x => x, StringComparer.OrdinalIgnoreCase)
            .Cast<string>()
            .ToList();

    private List<SetCardItem> FilteredCards => ApplyFiltersAndSort();

    protected override async Task OnParametersSetAsync()
    {
        await LoadCardsAsync();
    }

    private async Task LoadCardsAsync()
    {
        isLoading = true;
        error = null;
        setName = "";
        allCards.Clear();

        try
        {
            if (string.IsNullOrWhiteSpace(SetId))
            {
                error = "No set was selected.";
                return;
            }

            var url = $"/api/catalog/sets/{Uri.EscapeDataString(SetId)}/cards";
            var cards = await Http.GetFromJsonAsync<List<SetCardItem>>(url);

            if (cards is null || cards.Count == 0)
            {
                error = "No cards were returned for this set.";
                return;
            }

            allCards.AddRange(cards);
            setName = allCards[0].SetName;
        }
        catch (Exception ex)
        {
            error = $"Failed to load set cards: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private string GetApiImageUrl(string? imageUrl)
    {
        if (string.IsNullOrWhiteSpace(imageUrl))
            return "";

        if (Uri.TryCreate(imageUrl, UriKind.Absolute, out _))
            return imageUrl;

        var baseAddress = Http.BaseAddress?.ToString();
        if (string.IsNullOrWhiteSpace(baseAddress))
            return imageUrl;

        return new Uri(new Uri(baseAddress), imageUrl.TrimStart('/')).ToString();
    }

    private List<SetCardItem> ApplyFiltersAndSort()
    {
        IEnumerable<SetCardItem> query = allCards;

        if (!string.IsNullOrWhiteSpace(searchTerm))
        {
            query = query.Where(card =>
                !string.IsNullOrWhiteSpace(card.Name) &&
                card.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(selectedRarity))
        {
            query = query.Where(card =>
                string.Equals(card.Rarity, selectedRarity, StringComparison.OrdinalIgnoreCase));
        }

        query = selectedSort switch
        {
            "name-asc" => query.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase),
            "name-desc" => query.OrderByDescending(x => x.Name, StringComparer.OrdinalIgnoreCase),
            "rarity" => query.OrderBy(x => x.Rarity, StringComparer.OrdinalIgnoreCase)
                             .ThenBy(x => ParseCardNumber(x.Number))
                             .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase),
            "price-asc" => query.OrderBy(x => x.MarketPrice ?? decimal.MaxValue)
                                .ThenBy(x => ParseCardNumber(x.Number))
                                .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase),
            "price-desc" => query.OrderByDescending(x => x.MarketPrice ?? decimal.MinValue)
                                 .ThenBy(x => ParseCardNumber(x.Number))
                                 .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase),
            _ => query.OrderBy(x => ParseCardNumber(x.Number))
                      .ThenBy(x => x.Number, StringComparer.OrdinalIgnoreCase)
                      .ThenBy(x => x.Name, StringComparer.OrdinalIgnoreCase)
        };

        return query.ToList();
    }

    private static int ParseCardNumber(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return int.MaxValue;

        var leftSide = value.Split('/')[0];
        var digits = new string(leftSide.TakeWhile(char.IsDigit).ToArray());

        return int.TryParse(digits, out var parsed) ? parsed : int.MaxValue;
    }

    private void ClearFilters()
    {
        searchTerm = "";
        selectedSort = "number";
        selectedRarity = "";
    }

    private void GoBack()
    {
        Navigation.NavigateTo("/sets");
    }

    private sealed class SetCardItem
    {
        public string ExternalId { get; set; } = "";
        public string Name { get; set; } = "";
        public string ImageUrl { get; set; } = "";
        public string SetId { get; set; } = "";
        public string SetName { get; set; } = "";
        public string Series { get; set; } = "";
        public string Number { get; set; } = "";
        public string Rarity { get; set; } = "";
        public decimal? MarketPrice { get; set; }
        public string TcgPlayerUrl { get; set; } = "";
    }
}