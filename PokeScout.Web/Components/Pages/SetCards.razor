.sets-page {
    display: grid;
    gap: 1.5rem;
}

.sets-hero {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.5rem;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
}

.sets-eyebrow {
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #8fb9ff;
    margin-bottom: 0.5rem;
}

.sets-hero h1 {
    margin: 0 0 0.5rem 0;
}

.sets-hero p {
    margin: 0;
    color: rgba(255, 255, 255, 0.72);
    line-height: 1.6;
    max-width: 720px;
}

.back-button {
    border: 1px solid rgba(255, 255, 255, 0.12);
    background: rgba(255, 255, 255, 0.05);
    color: white;
    border-radius: 999px;
    padding: 0.85rem 1.15rem;
    font-weight: 700;
    cursor: pointer;
    white-space: nowrap;
}

.back-button:hover {
    background: rgba(255, 255, 255, 0.1);
}

.sets-message {
    padding: 1rem 1.25rem;
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
}

.sets-message.error {
    color: #ff9b9b;
}

.sets-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1rem;
}

.set-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: left;
    border: 1px solid rgba(255, 255, 255, 0.08);
    background: rgba(255, 255, 255, 0.04);
    border-radius: 22px;
    padding: 1rem;
    cursor: pointer;
    transition: transform 0.2s ease, border-color 0.2s ease, background 0.2s ease;
}

.set-card:hover {
    transform: translateY(-4px);
    border-color: rgba(102, 126, 234, 0.5);
    background: rgba(255, 255, 255, 0.07);
}

.set-image-wrap {
    height: 130px;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.03);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.set-image {
    max-width: 90%;
    max-height: 90%;
    object-fit: contain;
    display: block;
}

.set-image-fallback {
    padding: 1rem;
    text-align: center;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.8);
}

.set-info h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1rem;
}

.set-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
}

.set-meta span {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.72);
    padding: 0.35rem 0.55rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
}

@@media (max-width: 720px) {
    .sets-hero {
        flex-direction: column;
    }

    .back-button {
        width: 100%;
    }
}