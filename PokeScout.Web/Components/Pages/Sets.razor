@page "/sets"
@inject NavigationManager Navigation

<PageTitle>Sets</PageTitle>

<div class="sets-browser">
    <div class="sets-header-row">
        <div class="sets-header-copy">
            <h1>Browse Sets</h1>
            <p>
                Explore Pokémon TCG sets from newest to oldest. Click a set to view its cards.
            </p>
        </div>

        <button class="sets-back-link" @onclick="GoBackToCatalog">
            ← Back
        </button>
    </div>

    @foreach (var series in GroupedSets)
    {
        <section class="series-section">
            <h2 class="series-title">@series.Key</h2>

            <div class="series-grid">
                @foreach (var set in series)
                {
                    <button class="set-tile" @onclick="() => OpenSet(set)">
                        <div class="set-logo-box">
                            @if (!string.IsNullOrWhiteSpace(set.ImageFileName))
                            {
                                <img src="@GetSetImagePath(set.ImageFileName)"
                                     alt="@set.Name"
                                     class="set-logo"
                                     loading="lazy"
                                     onerror="this.style.display='none'; this.nextElementSibling.classList.add('show');" />
                            }

                            <div class="set-logo-fallback @(string.IsNullOrWhiteSpace(set.ImageFileName) ? "show" : "")">
                                @set.Name
                            </div>
                        </div>

                        <div class="set-tile-body">
                            <div class="set-name">@set.Name</div>

                            <div class="set-detail-line">
                                <span>@set.ReleaseDateText</span>
                                @if (!string.IsNullOrWhiteSpace(set.Code))
                                {
                                    <span>•</span>
                                    <span>@set.Code</span>
                                }
                            </div>
                        </div>
                    </button>
                }
            </div>
        </section>
    }
</div>

@code {
    private IEnumerable<IGrouping<string, LocalSetItem>> GroupedSets =>
        AllSets
            .OrderBy(s => s.SeriesSortOrder)
            .ThenByDescending(s => s.ReleaseDate)
            .GroupBy(s => s.Series);

    private void GoBackToCatalog()
    {
        Navigation.NavigateTo("/catalog");
    }

    private void OpenSet(LocalSetItem set)
    {
        // Change this route if your SetCards page uses a different URL.
        Navigation.NavigateTo($"/setcards/{set.Slug}");
    }

    private static string GetSetImagePath(string fileName)
    {
        return $"/images/sets/{fileName}";
    }

    private sealed class LocalSetItem
    {
        public string Name { get; init; } = "";
        public string Series { get; init; } = "";
        public int SeriesSortOrder { get; init; }
        public DateTime ReleaseDate { get; init; }
        public string ReleaseDateText => ReleaseDate.ToString("MMM d, yyyy");
        public string Code { get; init; } = "";
        public string Slug { get; init; } = "";
        public string ImageFileName { get; init; } = "";
    }

