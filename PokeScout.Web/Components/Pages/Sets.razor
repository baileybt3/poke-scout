@page "/sets"
@rendermode InteractiveServer
@using System.Net.Http.Json
@inject HttpClient Http
@inject NavigationManager Navigation
@using System.Text.Json.Serialization

<PageTitle>Sets</PageTitle>

<div class="sets-browser">
    <div class="sets-header-row">
        <div class="sets-header-copy">
            <h1>Browse Sets</h1>
            <p>
                Explore Pokémon TCG sets from newest to oldest. Click a set to view its cards.
            </p>
        </div>

        <button class="sets-back-link" @onclick="GoBackToCatalog">
            ← Back
        </button>
    </div>

    @if (isLoading)
    {
        <div class="sets-message">Loading set links...</div>
    }
    else if (!string.IsNullOrWhiteSpace(error))
    {
        <div class="sets-message error">@error</div>
    }
    else
    {
        @foreach (var series in GroupedSets)
        {
            <section class="series-section">
                <h2 class="series-title">@series.Key</h2>

                <div class="series-grid">
                    @foreach (var set in series)
                    {
                        <button class="set-tile"
                                type="button"
                                title="@GetSetTileTitle(set)"
                                aria-label="@GetSetTileTitle(set)"
                                disabled="@(!set.IsAvailable)"
                                @onclick="() => OpenSet(set)">
                            <div class="set-logo-box">
                                @if (set.HasImage)
                                {
                                    <img src="@GetSetImagePath(set.ImageFileName)"
                                         alt="@set.Name"
                                         class="set-logo"
                                         loading="lazy"
                                         onerror="this.style.display='none'; this.nextElementSibling.classList.add('show');" />
                                }

                                <div class="set-logo-fallback @(!set.HasImage ? "show" : "")">
                                    @set.Name
                                </div>
                            </div>

                            <div class="set-name">@set.Name</div>

                            <div class="set-meta-row">
                                <span class="set-release-date">@set.ReleaseDateText</span>

                                @if (!string.IsNullOrWhiteSpace(set.IconFileName))
                                {
                                    <img src="@GetSetIconPath(set.IconFileName)"
                                         alt="@($"{set.Name} icon")"
                                         class="set-expansion-icon"
                                         loading="lazy" />
                                }
                                else
                                {
                                    <div class="set-expansion-icon placeholder" aria-hidden="true"></div>
                                }
                            </div>
                        </button>
                    }
                </div>
            </section>
        }
    }
</div>

@code {
    private bool isLoading = true;
    private string? error;

    private IEnumerable<IGrouping<string, LocalSetItem>> GroupedSets =>
        AllSets
            .OrderBy(s => s.SeriesSortOrder)
            .ThenByDescending(s => s.ReleaseDate)
            .ThenBy(s => s.Name)
            .GroupBy(s => s.Series);

    protected override async Task OnInitializedAsync()
    {
        await LoadApiSetIdsAsync();
    }

    private async Task LoadApiSetIdsAsync()
    {
        isLoading = true;
        error = null;

        try
        {
            var apiSets = await Http.GetFromJsonAsync<List<CatalogSetLookup>>("/api/catalog/sets") ?? [];

            foreach (var localSet in AllSets)
            {
                var match = FindBestMatch(localSet, apiSets);

                if (match is not null && !string.IsNullOrWhiteSpace(match.EffectiveSetKey))
                {
                    // Prefer the live API key when we get one.
                    localSet.ApiSetId = match.EffectiveSetKey;
                }
                // IMPORTANT:
                // If no match is found, keep the existing hardcoded ApiSetId/Code fallback.
                // Do NOT blank it out, or the button becomes dead.
            }
        }
        catch (Exception ex)
        {
            error = $"Failed to load set links: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static CatalogSetLookup? FindBestMatch(
    LocalSetItem localSet,
    List<CatalogSetLookup> apiSets)
    {
        var localName = NormalizeKey(localSet.Name);
        var localCode = NormalizeKey(localSet.Code);

        return apiSets
            .Select(apiSet => new
            {
                Set = apiSet,
                Score = GetMatchScore(localName, localCode, apiSet)
            })
            .Where(x => x.Score > 0)
            .OrderByDescending(x => x.Score)
            .ThenBy(x => ReleaseDateDistance(x.Set, localSet.ReleaseDate))
            .Select(x => x.Set)
            .FirstOrDefault();
    }

    private static int GetMatchScore(string localName, string localCode, CatalogSetLookup apiSet)
    {
        var apiName = NormalizeKey(apiSet.Name);
        var apiCode = NormalizeKey(apiSet.SetCode);

        if (!string.IsNullOrWhiteSpace(localCode) && apiCode == localCode)
            return 300;

        if (apiName == localName)
            return 200;

        if (!string.IsNullOrWhiteSpace(apiName) &&
            (apiName.Contains(localName) || localName.Contains(apiName)))
            return 100;

        return 0;
    }

    private static int ReleaseDateDistance(CatalogSetLookup apiSet, DateTime localReleaseDate)
    {
        var apiReleaseDate = apiSet.EffectiveReleaseDate;

        if (DateTime.TryParse(apiReleaseDate, out var parsed))
        {
            return Math.Abs((parsed.Date - localReleaseDate.Date).Days);
        }

        return int.MaxValue;
    }

    private static string NormalizeKey(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return string.Empty;

        return new string(value.Where(char.IsLetterOrDigit).ToArray()).ToLowerInvariant();
    }

    private void GoBackToCatalog()
    {
        Navigation.NavigateTo("/catalog");
    }

    private void OpenSet(LocalSetItem set)
    {
        var setKey = GetSetKey(set);

        if (string.IsNullOrWhiteSpace(setKey))
            return;

        Navigation.NavigateTo($"/setcards/{Uri.EscapeDataString(setKey)}");
    }

    private static string GetSetKey(LocalSetItem set)
    {
        if (!string.IsNullOrWhiteSpace(set.ApiSetId))
            return set.ApiSetId;

        if (!string.IsNullOrWhiteSpace(set.Code))
            return set.Code;

        return "";
    }

    private static string GetSetImagePath(string fileName)
    {
        return $"/images/sets/{fileName}";
    }

    private static string GetSetIconPath(string fileName)
    {
        return $"/images/set-icons/{fileName}";
    }

    private static string GetSetTileTitle(LocalSetItem set)
    {
        return set.IsAvailable
            ? $"Open {set.Name}"
            : $"{set.Name} is not linked yet";
    }

    private sealed class LocalSetItem
    {
        public string Name { get; init; } = "";
        public string Series { get; init; } = "";
        public int SeriesSortOrder { get; init; }
        public DateTime ReleaseDate { get; init; }
        public string ReleaseDateText => ReleaseDate.ToString("MMM d, yyyy");
        public string Code { get; init; } = "";
        public string Slug { get; init; } = "";
        public string ApiSetId { get; set; } = "";
        public string ImageFileName { get; init; } = "";
        public string IconFileName { get; init; } = "";
        public bool HasImage => !string.IsNullOrWhiteSpace(ImageFileName);
        public bool IsAvailable => !string.IsNullOrWhiteSpace(ApiSetId) || !string.IsNullOrWhiteSpace(Code);
    }

    private sealed class CatalogSetLookup
    {
        [JsonPropertyName("id")]
        public string Id { get; set; } = "";

        [JsonPropertyName("set_id")]
        public string SetId { get; set; } = "";

        [JsonPropertyName("set_code")]
        public string SetCode { get; set; } = "";

        [JsonPropertyName("name")]
        public string Name { get; set; } = "";

        [JsonPropertyName("series")]
        public string Series { get; set; } = "";

        [JsonPropertyName("releaseDate")]
        public string ReleaseDate { get; set; } = "";

        [JsonPropertyName("release_date")]
        public string ReleaseDateAlt { get; set; } = "";

        public string EffectiveSetKey =>
            !string.IsNullOrWhiteSpace(SetId) ? SetId :
            !string.IsNullOrWhiteSpace(Id) ? Id :
            SetCode;

        public string EffectiveReleaseDate =>
            !string.IsNullOrWhiteSpace(ReleaseDate) ? ReleaseDate : ReleaseDateAlt;
    }

